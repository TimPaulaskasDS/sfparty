{
	"name": "@ds-sfdc/sfparty",
	"version": "1.7.9",
	"description": "Salesforce metadata XML splitter for CI/CD",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/TimPaulaskasDS/sfparty.git"
	},
	"bin": {
		"sfparty": "dist/index.js"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"build:watch": "tsc --watch",
		"dev": "tsc && node dist/index.js",
		"test": "npm run build && vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "npm run build && vitest run --coverage",
		"lint": "biome check --max-diagnostics=1000 src/ test/",
		"lint:fix": "biome check --write --max-diagnostics=1000 src/ test/",
		"format": "biome format --write src/ test/",
		"prepare": "husky || true",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"salesforce,metadata,xml,split,yaml,json"
	],
	"author": "Tim Paulaskas",
	"license": "BSD-3-Clause",
	"dependencies": {
		"axios": "^1.13.2",
		"ci-info": "^4.1.0",
		"cli-color": "^2.0.4",
		"cli-spinners": "^2.9.2",
		"convert-hrtime": "^5.0.0",
		"js-yaml": "^4.1.1",
		"log-update": "^6.1.0",
		"marked": "^14.1.3",
		"marked-terminal": "^7.2.1",
		"pretty-quick": "^4.0.0",
		"semver": "^7.6.3",
		"util": "^0.12.5",
		"winston": "^3.17.0",
		"xml2js": "^0.6.2",
		"yargs": "^17.7.2"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.6.0",
		"@commitlint/config-conventional": "^19.6.0",
		"@types/cli-color": "^2.0.6",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.0.0",
		"@types/semver": "^7.5.8",
		"@types/xml2js": "^0.4.14",
		"@types/yargs": "^17.0.33",
		"@vitest/coverage-v8": "^4.0.10",
		"@vitest/ui": "^4.0.10",
		"eslint": "^9.16.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.10",
		"nodemon": "^3.1.7",
		"prettier": "^3.4.2",
		"typescript": "^5.6.0",
		"vitest": "^4.0.10"
	},
	"engines": {
		"node": ">=0.11"
	},
	"bugs": {
		"url": "https://github.com/TimPaulaskasDS/sfparty/issues"
	},
	"homepage": "https://github.com/TimPaulaskasDS/sfparty#readme",
	"directories": {
		"lib": "lib",
		"test": "tests"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		]
	}
}
